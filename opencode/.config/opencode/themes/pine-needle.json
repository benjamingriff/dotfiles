{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "base_dark": "#111111",
    "panel_dark": "#1f1d2e",
    "element_dark": "#26233a",
    "border_dark": "#403d52",
    "text_dark": "#e0def4",
    "muted_dark": "#6e6a86",
    "subtle_dark": "#908caa",
    "love_dark": "#eb6f92",
    "gold_dark": "#f6c177",
    "rose_dark": "#ebbcba",
    "pine_dark": "#3e9fb0",
    "foam_dark": "#9ccfd8",
