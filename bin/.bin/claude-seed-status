#!/usr/bin/env bash
#
# claude-seed-status — poll the claude_seed repo for new commits on its default
# branch and surface a tmux status-bar segment when your local checkout is behind.
#
# Modelled on ~/.bin/rs-ssm so it slots into the same rose-pine status bar.
#
# Subcommands:
#   poll         Check the remote (gh, falling back to git) and cache the result.
#                Run on an interval by launchd — this is the only networked part.
#   tmux-status  Print a rose-pine-coloured status segment from the cache. Cheap,
#                no network — safe to call every few seconds from the status bar.
#   review       Fast-forward the seed checkout and launch Claude Code running
#                /install-claude. Meant to be run inside a tmux popup.
#   ack          Dismiss the current change without pulling (clears the segment).
#
# Config (env overrides):
#   CLAUDE_SEED_DIR     path to the claude_seed checkout (default ~/px-repos/claude_seed)
#   CLAUDE_SEED_BRANCH  branch to track (default main)

set -euo pipefail

readonly SEED_DIR="${CLAUDE_SEED_DIR:-$HOME/px-repos/claude_seed}"
readonly BRANCH="${CLAUDE_SEED_BRANCH:-main}"
readonly REPO_SLUG="${CLAUDE_SEED_SLUG:-Proximie/claude_seed}"
readonly CACHE_FILE="${CLAUDE_SEED_CACHE:-$HOME/.claude/.seed-status}"
readonly ACK_FILE="${CLAUDE_SEED_ACK:-$HOME/.claude/.seed-ack}"

# --- rose-pine helpers (mirrored from rs-ssm so colours match the theme) ---

rose_pine_variant() {
  local variant
  variant="$(tmux show-option -gqv @rose_pine_variant 2>/dev/null || true)"
  if [[ -n "$variant" ]]; then printf '%s' "$variant"; else printf 'main'; fi
}

rose_pine_foam_color() {
  case "$(rose_pine_variant)" in
    dawn) printf '#56949f' ;;
    *)    printf '#9ccfd8' ;;
  esac
}

rose_pine_gold_color() {
  case "$(rose_pine_variant)" in
    dawn) printf '#ea9d34' ;;
    *)    printf '#f6c177' ;;
  esac
}

rose_pine_subtle_color() {
  case "$(rose_pine_variant)" in
    dawn) printf '#797593' ;;
    *)    printf '#908caa' ;;
  esac
}

rose_pine_right_separator() {
  local separator
  separator="$(tmux show-option -gqv @rose_pine_right_separator 2>/dev/null || true)"
  if [[ -n "$separator" ]]; then printf '%s' "$separator"; else printf ' < '; fi
}

# --- cache I/O (simple key=value lines so tmux-status needs no jq) ---

write_cache() {
  local ahead="$1" remote="$2" local_sha="$3" ok="$4" checked="$5"
  local tmp
  tmp="$(mktemp "${CACHE_FILE}.XXXXXX")"
  {
    printf 'ahead=%s\n' "$ahead"
    printf 'remote=%s\n' "$remote"
    printf 'local=%s\n' "$local_sha"
    printf 'ok=%s\n' "$ok"
    printf 'checked=%s\n' "$checked"
  } >"$tmp"
  mv -f "$tmp" "$CACHE_FILE"
}

# --- poll ---

cmd_poll() {
  local now local_sha="" remote_sha="" ahead=""
  now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

  if [[ ! -d "$SEED_DIR/.git" ]]; then
    write_cache 0 "" "" 0 "$now"
    echo "claude-seed-status: no git checkout at $SEED_DIR" >&2
    return 0
  fi

  local_sha="$(git -C "$SEED_DIR" rev-parse "refs/heads/$BRANCH" 2>/dev/null \
    || git -C "$SEED_DIR" rev-parse HEAD 2>/dev/null || true)"

  # Preferred path: gh (token auth, reliable under launchd where SSH-agent is absent).
  if command -v gh >/dev/null 2>&1; then
    remote_sha="$(gh api "repos/$REPO_SLUG/commits/$BRANCH" --jq '.sha' 2>/dev/null || true)"
    if [[ -n "$remote_sha" && -n "$local_sha" ]]; then
      ahead="$(gh api "repos/$REPO_SLUG/compare/$local_sha...$remote_sha" --jq '.ahead_by' 2>/dev/null || true)"
    fi
  fi

  # Fallback: plain git fetch (only mutates remote-tracking refs, never the tree).
  if [[ -z "$remote_sha" || -z "$ahead" ]]; then
    if git -C "$SEED_DIR" fetch -q origin "$BRANCH" 2>/dev/null; then
      remote_sha="$(git -C "$SEED_DIR" rev-parse FETCH_HEAD 2>/dev/null || true)"
      if [[ -n "$local_sha" && -n "$remote_sha" ]]; then
        ahead="$(git -C "$SEED_DIR" rev-list --count "${local_sha}..${remote_sha}" 2>/dev/null || true)"
      fi
    fi
  fi

  if [[ -z "$remote_sha" || -z "$ahead" ]]; then
    write_cache 0 "$remote_sha" "$local_sha" 0 "$now"
    echo "claude-seed-status: poll failed (no gh/git reachability)" >&2
    return 0
  fi

  write_cache "$ahead" "$remote_sha" "$local_sha" 1 "$now"
}

# --- tmux-status ---

cmd_tmux_status() {
  local ahead=0 remote="" ok=0 acked="" seg separator gold subtle
  separator="$(rose_pine_right_separator)"
  gold="$(rose_pine_gold_color)"
  subtle="$(rose_pine_subtle_color)"

  if [[ ! -f "$CACHE_FILE" ]]; then
    printf '#[fg=%s]CLAUDE SEED:?#[fg=%s]%s#[default]' "$subtle" "$subtle" "$separator"
    return 0
  fi

  # shellcheck disable=SC1090
  . "$CACHE_FILE"
  [[ -f "$ACK_FILE" ]] && acked="$(cat "$ACK_FILE" 2>/dev/null || true)"

  if [[ "${ok:-0}" != "1" ]]; then
    printf '#[fg=%s]CLAUDE SEED:?#[fg=%s]%s#[default]' "$subtle" "$subtle" "$separator"
    return 0
  fi

  if [[ "${ahead:-0}" -gt 0 && "${remote:-}" != "$acked" ]]; then
    printf '#[fg=%s]CLAUDE SEED:↓%s#[fg=%s]%s#[default]' "$gold" "$ahead" "$subtle" "$separator"
  else
    printf '#[fg=%s]CLAUDE SEED:✓#[fg=%s]%s#[default]' "$subtle" "$subtle" "$separator"
  fi
}

# --- review (run inside a tmux popup) ---

cmd_review() {
  if [[ ! -d "$SEED_DIR/.git" ]]; then
    echo "No claude_seed checkout at $SEED_DIR."
    echo "Set CLAUDE_SEED_DIR or clone it, then try again."
    read -rp "Press enter to close…" _ || true
    return 0
  fi

  cd "$SEED_DIR"

  echo "== Updating claude_seed ($BRANCH) =="
  git fetch -q origin "$BRANCH" || echo "  (fetch failed — showing whatever is checked out)"

  local current clean
  current="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo '?')"
  clean="$(git status --porcelain 2>/dev/null)"

  if [[ "$current" == "$BRANCH" && -z "$clean" ]]; then
    if git merge --ff-only "origin/$BRANCH" 2>/dev/null; then
      echo "  Fast-forwarded to origin/$BRANCH."
    else
      echo "  Already up to date (or no fast-forward possible)."
    fi
  else
    echo "  Skipping auto-pull: on '$current'${clean:+ with uncommitted changes}."
    echo "  install-claude will read the current working tree as-is."
  fi

  echo
  echo "== What changed on the seed =="
  git --no-pager log --oneline "HEAD..origin/$BRANCH" 2>/dev/null | sed 's/^/  /' \
    || echo "  (nothing new)"
  echo

  # Clear the indicator — we're about to reconcile.
  "$0" ack >/dev/null 2>&1 || true

  echo "== Launching Claude Code → /install-claude =="
  echo
  exec claude "/install-claude"
}

# --- ack ---

cmd_ack() {
  local remote=""
  if [[ -f "$CACHE_FILE" ]]; then
    # shellcheck disable=SC1090
    . "$CACHE_FILE"
  fi
  printf '%s' "${remote:-}" >"$ACK_FILE"
  echo "Dismissed. The SEED indicator will clear until the next new commit."
}

# --- dispatch ---

main() {
  local cmd="${1:-}"
  [[ $# -gt 0 ]] && shift || true
  case "$cmd" in
    poll)        cmd_poll "$@" ;;
    tmux-status) cmd_tmux_status "$@" ;;
    review)      cmd_review "$@" ;;
    ack)         cmd_ack "$@" ;;
    *)
      cat <<EOF
Usage: claude-seed-status <poll|tmux-status|review|ack>

  poll         Check the remote and cache the result (run by launchd).
  tmux-status  Print the rose-pine status segment from the cache.
  review       Fast-forward the seed and launch Claude Code /install-claude.
  ack          Dismiss the current change without pulling.
EOF
      [[ "$cmd" == "" || "$cmd" == "-h" || "$cmd" == "--help" ]] && return 0
      return 2
      ;;
  esac
}

main "$@"
