#!/bin/zsh

set -euo pipefail

start_path="${1:-$PWD}"
yazi_nvim_init="${HOME}/.bin/tmux-popup-yazi.nvim.lua"

show_error() {
  local message="$1"

  if [[ -n "${TMUX:-}" ]]; then
    tmux display-message "$message" >/dev/null 2>&1 || true
  fi

  echo "$message" >&2
  sleep 2
  exit 1
}

if [[ ! -d "$start_path" ]]; then
  show_error "Path does not exist: $start_path"
fi

cd "$start_path"

if ! command -v yazi >/dev/null 2>&1; then
  show_error "yazi is not on PATH inside tmux."
fi

if command -v nvim >/dev/null 2>&1 && [[ -f "$yazi_nvim_init" ]]; then
  exec nvim -u "$yazi_nvim_init" -- "$start_path"
fi

exec yazi
