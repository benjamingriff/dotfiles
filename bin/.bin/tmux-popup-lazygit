#!/bin/zsh

set -euo pipefail

start_path="${1:-$PWD}"

show_error() {
  local message="$1"

  if [[ -n "${TMUX:-}" ]]; then
    tmux display-message "$message" >/dev/null 2>&1 || true
  fi

  echo "$message" >&2
  sleep 2
  exit 1
}

if [[ ! -d "$start_path" ]]; then
  show_error "Path does not exist: $start_path"
fi

repo_root="$(cd "$start_path" && git rev-parse --show-toplevel 2>/dev/null)" || \
  show_error "Current pane is not inside a Git repository."

cd "$repo_root"

if ! command -v lazygit >/dev/null 2>&1; then
  show_error "lazygit is not on PATH inside tmux."
fi

lazygit
exit_code=$?

if [[ $exit_code -ne 0 ]]; then
  show_error "lazygit exited with status $exit_code"
fi
