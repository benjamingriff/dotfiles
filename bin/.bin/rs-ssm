#!/usr/bin/env bash

set -euo pipefail

readonly SCRIPT_PATH="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
readonly TMUX_SESSION_NAME="${RS_SSM_TMUX_SESSION:-rs-ssm}"
readonly DEFAULT_CONFIG_FILE="${RS_SSM_ENV_FILE:-$HOME/.bin/rs-ssm.env}"

die() {
  echo "Error: $*" >&2
  exit 1
}

usage() {
  cat <<'EOF'
Usage:
  rs-ssm connect <profile>
  rs-ssm status [profile]
  rs-ssm stop <profile>
  rs-ssm logs <profile>
  rs-ssm attach <profile>
  rs-ssm tmux-status

Config:
  Default config file: ~/.bin/rs-ssm.env
  Override with: RS_SSM_ENV_FILE=/path/to/file
EOF
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "Missing required command: $1"
}

load_config() {
  local config_file="$1"
  local mode="${2:-strict}"

  if [[ ! -f "$config_file" ]]; then
    if [[ "$mode" == "optional" ]]; then
      return 1
    fi
    die "Config file not found: $config_file. Copy ~/.bin/rs-ssm.env.example to ~/.bin/rs-ssm.env and fill in your values."
  fi

  # shellcheck disable=SC1090
  . "$config_file"

  if [[ -z "${RS_SSM_PROFILES:-}" ]]; then
    if [[ "$mode" == "optional" ]]; then
      return 1
    fi
    die "RS_SSM_PROFILES is empty in $config_file"
  fi

  CONFIG_FILE="$config_file"
}

profile_key() {
  printf '%s\n' "$1" | tr '[:lower:]-' '[:upper:]_'
}

has_profile() {
  local wanted="$1"
  local profile

  for profile in $RS_SSM_PROFILES; do
    if [[ "$profile" == "$wanted" ]]; then
      return 0
    fi
  done

  return 1
}

profile_var_name() {
  local profile="$1"
  local suffix="$2"
  local key

  key="$(profile_key "$profile")"
  printf 'RS_SSM_%s_%s' "$key" "$suffix"
}

profile_value() {
  local var_name

  var_name="$(profile_var_name "$1" "$2")"
  printf '%s' "${!var_name-}"
}

require_profile_config() {
  local profile="$1"
  local suffix
  local value

  has_profile "$profile" || die "Unknown profile: $profile"

  for suffix in PROFILE REGION TARGET HOST REMOTE_PORT LOCAL_PORT; do
    value="$(profile_value "$profile" "$suffix")"
    [[ -n "$value" ]] || die "Missing $(profile_var_name "$profile" "$suffix") in $CONFIG_FILE"
  done
}

window_target() {
  printf '%s:%s' "$TMUX_SESSION_NAME" "$1"
}

session_exists() {
  tmux has-session -t "$TMUX_SESSION_NAME" 2>/dev/null
}

window_exists() {
  local profile="$1"

  session_exists || return 1
  tmux list-windows -t "$TMUX_SESSION_NAME" -F '#{window_name}' 2>/dev/null | grep -Fxq -- "$profile"
}

port_listening() {
  local port="$1"
  lsof -nP -iTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1
}

profile_state() {
  local profile="$1"
  local local_port

  local_port="$(profile_value "$profile" "LOCAL_PORT")"

  if window_exists "$profile"; then
    if [[ -n "$local_port" ]] && port_listening "$local_port"; then
      printf 'active'
    else
      printf 'stale'
    fi
    return 0
  fi

  printf 'inactive'
}

start_tmux_window() {
  local profile="$1"
  local command_string

  printf -v command_string '%q internal-run %q %q' "$SCRIPT_PATH" "$profile" "$CONFIG_FILE"

  if session_exists; then
    tmux new-window -d -t "$TMUX_SESSION_NAME" -n "$profile" "$command_string"
  else
    tmux new-session -d -s "$TMUX_SESSION_NAME" -n "$profile" "$command_string"
  fi
}

wait_for_connection() {
  local profile="$1"
  local local_port
  local attempt

  local_port="$(profile_value "$profile" "LOCAL_PORT")"

  for attempt in 1 2 3 4 5; do
    if [[ "$(profile_state "$profile")" == "active" ]]; then
      echo "$profile is active on localhost:$local_port"
      return 0
    fi
    sleep 1
  done

  echo "$profile is starting in tmux session $TMUX_SESSION_NAME."
  echo "If auth or MFA input is waiting, run: rs-ssm attach $profile"
}

cmd_connect() {
  local profile="${1:-}"

  [[ -n "$profile" ]] || die "Usage: rs-ssm connect <profile>"

  require_command tmux
  require_command aws
  require_command session-manager-plugin
  require_command lsof
  load_config "$DEFAULT_CONFIG_FILE"
  require_profile_config "$profile"

  case "$(profile_state "$profile")" in
    active)
      echo "$profile is already active on localhost:$(profile_value "$profile" "LOCAL_PORT")"
      return 0
      ;;
    stale)
      tmux kill-window -t "$(window_target "$profile")" >/dev/null 2>&1 || true
      ;;
  esac

  start_tmux_window "$profile"
  wait_for_connection "$profile"
}

cmd_status() {
  local profile="${1:-}"
  local current_profile
  local state

  require_command tmux
  require_command lsof
  load_config "$DEFAULT_CONFIG_FILE"

  if [[ -n "$profile" ]]; then
    require_profile_config "$profile"
    state="$(profile_state "$profile")"
    printf '%-16s %-8s localhost:%s -> %s:%s (%s via %s)\n' \
      "$profile" \
      "$state" \
      "$(profile_value "$profile" "LOCAL_PORT")" \
      "$(profile_value "$profile" "HOST")" \
      "$(profile_value "$profile" "REMOTE_PORT")" \
      "$(profile_value "$profile" "REGION")" \
      "$(profile_value "$profile" "TARGET")"
    return 0
  fi

  for current_profile in $RS_SSM_PROFILES; do
    require_profile_config "$current_profile"
    state="$(profile_state "$current_profile")"
    printf '%-16s %-8s localhost:%s -> %s:%s (%s via %s)\n' \
      "$current_profile" \
      "$state" \
      "$(profile_value "$current_profile" "LOCAL_PORT")" \
      "$(profile_value "$current_profile" "HOST")" \
      "$(profile_value "$current_profile" "REMOTE_PORT")" \
      "$(profile_value "$current_profile" "REGION")" \
      "$(profile_value "$current_profile" "TARGET")"
  done
}

cmd_stop() {
  local profile="${1:-}"

  [[ -n "$profile" ]] || die "Usage: rs-ssm stop <profile>"

  require_command tmux
  load_config "$DEFAULT_CONFIG_FILE"
  require_profile_config "$profile"

  if window_exists "$profile"; then
    tmux kill-window -t "$(window_target "$profile")"
    echo "Stopped $profile"
    return 0
  fi

  echo "$profile is not running"
}

cmd_logs() {
  local profile="${1:-}"

  [[ -n "$profile" ]] || die "Usage: rs-ssm logs <profile>"

  require_command tmux
  load_config "$DEFAULT_CONFIG_FILE"
  require_profile_config "$profile"
  window_exists "$profile" || die "No tmux window found for $profile"

  tmux capture-pane -p -t "$(window_target "$profile")" -S -200
}

cmd_attach() {
  local profile="${1:-}"

  [[ -n "$profile" ]] || die "Usage: rs-ssm attach <profile>"

  require_command tmux
  load_config "$DEFAULT_CONFIG_FILE"
  require_profile_config "$profile"
  window_exists "$profile" || die "No tmux window found for $profile"

  if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$TMUX_SESSION_NAME" \; select-window -t "$(window_target "$profile")"
  else
    tmux attach-session -t "$TMUX_SESSION_NAME" \; select-window -t "$(window_target "$profile")"
  fi
}

rose_pine_variant() {
  local variant

  variant="$(tmux show-option -gqv @rose_pine_variant 2>/dev/null || true)"

  if [[ -n "$variant" ]]; then
    printf '%s' "$variant"
  else
    printf 'main'
  fi
}

rose_pine_foam_color() {
  case "$(rose_pine_variant)" in
    dawn)
      printf '#56949f'
      ;;
    moon)
      printf '#9ccfd8'
      ;;
    *)
      printf '#9ccfd8'
      ;;
  esac
}

rose_pine_subtle_color() {
  case "$(rose_pine_variant)" in
    dawn)
      printf '#797593'
      ;;
    moon)
      printf '#908caa'
      ;;
    *)
      printf '#908caa'
      ;;
  esac
}

rose_pine_right_separator() {
  local separator

  separator="$(tmux show-option -gqv @rose_pine_right_separator 2>/dev/null || true)"

  if [[ -n "$separator" ]]; then
    printf '%s' "$separator"
  else
    printf ' < '
  fi
}

cmd_tmux_status() {
  local profile
  local state
  local total=0
  local active_count=0
  local stale_count=0
  local first_active=""
  local active_color
  local inactive_color
  local separator

  if ! command -v tmux >/dev/null 2>&1; then
    printf 'RS:down'
    return 0
  fi

  if ! command -v lsof >/dev/null 2>&1; then
    printf 'RS:down'
    return 0
  fi

  if ! load_config "$DEFAULT_CONFIG_FILE" optional; then
    printf 'RS:down'
    return 0
  fi

  active_color="$(rose_pine_foam_color)"
  inactive_color="$(rose_pine_subtle_color)"
  separator="$(rose_pine_right_separator)"

  for profile in $RS_SSM_PROFILES; do
    total=$((total + 1))
    state="$(profile_state "$profile")"

    case "$state" in
      active)
        active_count=$((active_count + 1))
        if [[ -z "$first_active" ]]; then
          first_active="$profile"
        fi
        ;;
      stale)
        stale_count=$((stale_count + 1))
        ;;
    esac
  done

  if [[ "$active_count" -eq 0 ]]; then
    if [[ "$stale_count" -gt 0 ]]; then
      printf '#[fg=%s]RS:stale#[fg=%s]%s#[default]' "$inactive_color" "$inactive_color" "$separator"
    else
      printf '#[fg=%s]RS:down#[fg=%s]%s#[default]' "$inactive_color" "$inactive_color" "$separator"
    fi
    return 0
  fi

  if [[ "$active_count" -eq 1 ]]; then
    printf '#[fg=%s]RS:%s#[fg=%s]%s#[default]' "$active_color" "$first_active" "$inactive_color" "$separator"
    return 0
  fi

  printf '#[fg=%s]RS:%s/%s#[fg=%s]%s#[default]' "$active_color" "$active_count" "$total" "$inactive_color" "$separator"
}

cmd_internal_run() {
  local profile="${1:-}"
  local config_file="${2:-$DEFAULT_CONFIG_FILE}"
  local aws_profile
  local region
  local target
  local host
  local remote_port
  local local_port
  local exit_code

  [[ -n "$profile" ]] || die "Usage: rs-ssm internal-run <profile> <config-file>"

  require_command aws
  require_command session-manager-plugin
  load_config "$config_file"
  require_profile_config "$profile"

  aws_profile="$(profile_value "$profile" "PROFILE")"
  region="$(profile_value "$profile" "REGION")"
  target="$(profile_value "$profile" "TARGET")"
  host="$(profile_value "$profile" "HOST")"
  remote_port="$(profile_value "$profile" "REMOTE_PORT")"
  local_port="$(profile_value "$profile" "LOCAL_PORT")"

  echo "[rs-ssm] starting profile $profile"
  echo "[rs-ssm] localhost:$local_port -> $host:$remote_port via $target in $region"
  echo "[rs-ssm] attach here if MFA or auth input is required"
  echo

  set +e
  aws ssm start-session \
    --target "$target" \
    --region "$region" \
    --document-name AWS-StartPortForwardingSessionToRemoteHost \
    --parameters "host=$host,portNumber=$remote_port,localPortNumber=$local_port" \
    --profile "$aws_profile"
  exit_code=$?
  set -e

  echo
  echo "[rs-ssm] session for $profile exited with code $exit_code at $(date '+%Y-%m-%d %H:%M:%S')"
  echo "[rs-ssm] run 'rs-ssm connect $profile' to recreate it or 'rs-ssm stop $profile' to close this window"

  while true; do
    sleep 3600
  done
}

main() {
  local command="${1:-}"

  case "$command" in
    connect)
      shift
      cmd_connect "$@"
      ;;
    status)
      shift
      cmd_status "$@"
      ;;
    stop)
      shift
      cmd_stop "$@"
      ;;
    logs)
      shift
      cmd_logs "$@"
      ;;
    attach)
      shift
      cmd_attach "$@"
      ;;
    tmux-status)
      shift
      cmd_tmux_status "$@"
      ;;
    internal-run)
      shift
      cmd_internal_run "$@"
      ;;
    ""|-h|--help|help)
      usage
      ;;
    *)
      die "Unknown command: $command"
      ;;
  esac
}

main "$@"
