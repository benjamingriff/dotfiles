#!/bin/zsh

set -euo pipefail

if [[ $# -lt 2 ]]; then
  echo "Usage: review-refs <base_ref> <head_ref> [git diff args...]" >&2
  exit 1
fi

base_ref="$1"
head_ref="$2"
shift 2

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || {
  echo "review-refs must be run inside a git repository." >&2
  exit 1
}

cd "$repo_root"
git diff --find-renames --no-color "$base_ref...$head_ref" "$@" | hunk patch -
