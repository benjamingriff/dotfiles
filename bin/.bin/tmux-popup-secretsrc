#!/bin/zsh

set -euo pipefail

secretsrc_cmd="${HOME}/go/bin/secretsrc"

show_error() {
  local message="$1"

  if [[ -n "${TMUX:-}" ]]; then
    tmux display-message "$message" >/dev/null 2>&1 || true
  fi

  echo "$message" >&2
  sleep 2
  exit 1
}

if command -v secretsrc >/dev/null 2>&1; then
  exec secretsrc
fi

if [[ -x "$secretsrc_cmd" ]]; then
  exec "$secretsrc_cmd"
fi

show_error "secretsrc was not found on PATH or at $secretsrc_cmd."
